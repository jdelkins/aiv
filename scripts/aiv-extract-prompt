#!/usr/bin/env bash
set -euo pipefail

file="$1"
firstline="$2"
lastline="$3"

# -d '' reads until EOF including all newlines; || true because read returns 1
# on EOF. This preserves trailing newlines that command substitution would strip.
IFS= read -r -d '' input </dev/stdin || true

if [[ "$input" == *$'\n' ]]; then
	input_had_trailing_newline=true
else
	input_had_trailing_newline=false
fi

prompt="$(printf '%s' "$input" | sed -n 's/^[[:space:]]*## prompt:[[:space:]]*//p' | sed 's/[[:space:]]*$//')"
body="$(printf '%s' "$input" | sed '/^[[:space:]]*## prompt:/d')"
prompt_line_count="$(printf '%s' "$input" | grep -c '^[[:space:]]*## prompt:')"
adjusted_last="$((lastline - prompt_line_count))"

# Capture leading whitespace from the first non-empty line of the input body.
first_body_line="$(printf '%s' "$body" | grep -m1 '.')"
leading_ws="$(printf '%s' "$first_body_line" | sed 's/\(^[[:space:]]*\).*/\1/')"

output="$(printf '%s' "$body" | aiv -X -c "stdin,file=$file,range=$firstline:$adjusted_last" "$prompt" 2>/dev/null)"

# Unconditionally replace the leading whitespace of the first output line
# with the leading whitespace captured from the input.
first_out_line="$(printf '%s' "$output" | head -1)"
rest_out="$(printf '%s' "$output" | tail -n +2)"
first_out_line="${leading_ws}$(printf '%s' "$first_out_line" | sed 's/^[[:space:]]*//')"

if [ -n "$rest_out" ]; then
	printf '%s\n%s' "$first_out_line" "$rest_out"
else
	printf '%s' "$first_out_line"
fi

# Append trailing newline if the original input had one.
if [ "$input_had_trailing_newline" = true ]; then
	printf '\n'
fi
